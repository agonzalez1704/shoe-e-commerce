# Supabase — from `supabase status` (local) or project settings (cloud)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# server-only. NEVER expose to client. used for service-role RPCs
# (commit_order, cancel_order, set_order_amounts, guest create_order).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Conekta (Phase 2 — OXXO / SPEI / card, MXN)
CONEKTA_PRIVATE_KEY=key_xxx
NEXT_PUBLIC_CONEKTA_PUBLIC_KEY=key_xxx       # client-side card tokenization (Conekta.js)
CONEKTA_WEBHOOK_SECRET=long-random-string    # appended as ?secret= on the webhook URL

# CFDI / PAC (facturación) — Facturama. Sandbox: https://apisandbox.facturama.mx
PAC_API_USER=
PAC_API_PASSWORD=
PAC_BASE_URL=
PAC_EXPEDITION_ZIP=     # CP fiscal del emisor (lugar de expedición)

# Resend (order emails)
RESEND_API_KEY=
EMAIL_FROM=sole&co <pedidos@soleco.mx>

# Vercel Cron auth (expire-orders route). Set the same value in Vercel project env.
CRON_SECRET=

# Public site URL (canonical, sitemap, OG)
NEXT_PUBLIC_SITE_URL=https://soleco.mx

# Active brand (white-label). Keys defined in lib/brand.ts
NEXT_PUBLIC_BRAND=soleco

# auto-toon (toon-converter) — multi-angle product image generation
TOON_API_URL=https://app.calzadoblade-toon.example
TOON_API_KEY=toon_xxx

# MCP server (sales/inventory) bearer token
MCP_BEARER_TOKEN=

# Kapso WhatsApp sales assistant
KAPSO_API_KEY=
KAPSO_API_BASE_URL=https://api.kapso.ai
KAPSO_PHONE_NUMBER_ID=
KAPSO_WEBHOOK_SECRET=
KAPSO_ASESORES=          # números WhatsApp de asesores, separados por coma
# Agent LLM (OpenRouter)
OPENROUTER_API_KEY=
OPENROUTER_AGENT_MODEL=anthropic/claude-sonnet-4.6

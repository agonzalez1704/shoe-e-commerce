{
  "name": "shoe-store",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "gen:types": "SUPABASE_ACCESS_TOKEN=${SUPABASE_ACCESS_TOKEN:-sbp_dummy_local} supabase gen types typescript --local > types/database.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:migrate": "supabase migration up && pnpm gen:types",
    "db:reset": "supabase db reset && pnpm gen:types && pnpm seed:images",
    "seed:images": "node --env-file=.env.local scripts/seed-images.mjs",
    "kapso:register": "node --env-file=.env.local scripts/register-kapso-webhook.mjs",
    "setup": "supabase start && supabase db reset && pnpm gen:types && pnpm seed:images"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@phosphor-icons/react": "^2.1.7",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "mcp-handler": "^1.1.0",
    "next": "^15.1.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-credit-cards-2": "^1.2.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
